      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git init:*)",
      "Bash(go version *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "Set-Location 'D:\\eulogia\\eupanel'; git add -A; $diff = git diff --cached --quiet 2>&1; if ($LASTEXITCODE -ne 0) { $file = $env:CLAUDE_TOOL_INPUT_FILE_PATH; $name = if ($file) { Split-Path $file -Leaf } else { 'frontend' }; git commit -m \"chore: auto-save $name\" 2>&1 | Out-Null }",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ]
  }
}
